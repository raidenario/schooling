{;; ============================================================================
 ;; School — backend Clojure sobre embabel-clj (ADR-0006).
 ;;
 ;;   :spike — Fase 0: servidor WS do spike-gate (ADR-0003)
 ;;   :dev   — nREPL ao lado da plataforma viva
 ;;
 ;; Pré-requisitos: embabel-clj clonado em ../../embabel-lab/embabel-clj e os
 ;; jars embabel 0.5.0-SNAPSHOT no ~/.m2 (já publicados pelo embabel-lab).
 ;; ============================================================================
 :paths ["src" "resources"]

 :mvn/repos
 {"central"           {:url "https://repo1.maven.org/maven2/"}
  "clojars"           {:url "https://repo.clojars.org/"}
  "spring-milestones" {:url "https://repo.spring.io/milestone"}
  "embabel-releases"  {:url "https://repo.embabel.com/artifactory/libs-release"}
  "embabel-snapshots" {:url "https://repo.embabel.com/artifactory/libs-snapshot"}}

 :deps
 {org.clojure/clojure {:mvn/version "1.12.1"}
  ;; versões pinadas nas que o embabel-lab provou (ADR-0006). Deps DIRETAS
  ;; vencem as transitivas do embabel-clj (que declara starter 0.4.0).
  com.embabel.agent/embabel-agent-api            {:mvn/version "0.5.0-SNAPSHOT"}
  com.embabel.agent/embabel-agent-starter        {:mvn/version "0.5.0-SNAPSHOT"}
  com.embabel.agent/embabel-agent-starter-openai {:mvn/version "0.5.0-SNAPSHOT"}
  io.local/embabel-clj {:local/root "../../embabel-lab/embabel-clj"}
  ;; servidor WebSocket do TUI (default reversível do School.md)
  http-kit/http-kit    {:mvn/version "2.8.0"}
  cheshire/cheshire    {:mvn/version "5.13.0"}
  ;; Fase 2a — Agenda FSRS no SQLite (ADR-0002: dado temporal fora do vault)
  com.github.seancorfield/next.jdbc {:mvn/version "1.3.955"}
  org.xerial/sqlite-jdbc            {:mvn/version "3.46.1.3"}
  ;; Fase 2b — memória fina do professor (ADR-0005): DICE do ~/.m2
  ;; (cd ../../embabel-lab/dice && mvn install -pl dice -am -DskipTests)
  ;; + chronicle irmão. slf4j-simple excluído: quem loga aqui é o logback do
  ;; Spring (dois providers SLF4J = IllegalStateException no boot).
  com.embabel.dice/dice   {:mvn/version "0.1.1-SNAPSHOT"}
  io.local/dice-chronicle {:local/root "../../embabel-lab/dice-chronicle"
                           :exclusions [org.slf4j/slf4j-simple]}}

 :aliases
 {;; Fase 1: clojure -M:server  (WS em ws://localhost:7777; TUI abre a matéria)
  :server {:main-opts ["-m" "school.server"]}

  ;; Fase 0: clojure -M:spike  (WS em ws://localhost:7777)
  :spike {:main-opts ["-m" "school.spike"]}

  ;; smoke offline (sem LLM): aponte SCHOOL_VAULT_ROOT/SCHOOL_EVENTS_FILE
  ;; para um diretório descartável e rode clojure -M:smoke
  :smoke {:extra-paths ["dev"]
          :main-opts   ["-m" "school.dev-smoke"]}

  ;; renderiza a prova fria de uma matéria a partir do prova-fria.edn (teste)
  :render-fixture {:extra-paths ["dev"]
                   :main-opts   ["-m" "school.dev-render-fixture"]}

  ;; renderiza uma aula de exemplo (ADR-0008) para inspeção visual
  :render-aula {:extra-paths ["dev"]
                :main-opts   ["-m" "school.dev-render-aula"]}

  ;; ciclo offline da Fase 2a (cards/agenda/review) — raízes descartáveis:
  ;; SCHOOL_AGENDA_DB/SCHOOL_VAULT_ROOT/SCHOOL_EVENTS_FILE + clojure -M:f2a-test
  :f2a-test {:extra-paths ["dev"]
             :main-opts   ["-m" "school.dev-f2a-test"]}

  ;; ciclo offline da Fase 2b (memória fina DICE+chronicle) — raiz descartável:
  ;; SCHOOL_CHRONICLE_LOG + clojure -M:f2b-test
  :f2b-test {:extra-paths ["dev"]
             :main-opts   ["-m" "school.dev-f2b-test"]}

  ;; benchmark do custo do DICE em processo: clojure -M:f2b-bench
  :f2b-bench {:extra-paths ["dev"]
              :main-opts   ["-m" "school.dev-f2b-bench"]}

  :dev {:extra-deps {nrepl/nrepl {:mvn/version "1.3.1"}}}}}
